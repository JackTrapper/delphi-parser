         {  ( "," 
        
        | "OR"  ) 
         ( NumberTypes 
        
        | ConstExpr  ) }
        .
VarSection =
        "VAR" 
         { VarDecl 
         [ Directive  ] 
        ";" 
         [ Directive 
        ";"  ] }
