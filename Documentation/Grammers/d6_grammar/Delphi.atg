VarDecl =
                                                  (. WriteStr( 'VarDecl--------->' +#13#10) ; .)
        IdentList 
        ":" 
         ( Type 
        
        | String  ) 
         [  ( "ABSOLUTE" 
         ( ConstExpr  ) ) 
        
        | "=" 
         [ "@"  ] 
        TypedConstant  ] 
                                                  (. //WriteStr( 'END VarDecl---------<' +#13#10) ; .)
        .
ExportedHeading =
         ( ProcedureHeading 
        
