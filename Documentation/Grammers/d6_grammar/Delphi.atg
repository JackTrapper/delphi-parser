        "PLATFORM"         | 
        "REINTRODUCE"         | 
        "SAFECALL"         | 
        "STDCALL"         | 
         [ "READONLY" 
        
        | "WRITEONLY"  ] 
        "DISPID" 
        NumberTypes
        .
ConstSection =
        "CONST" 
                                                  (. //WriteStr( 'In "CONST" ' +#13#10) ; .)
        ConstantDecl 
        ";" 
         { ConstantDecl 
        ";"  }
        .
ConstantDecl =
         ( BadNames 
        
        | Ident  ) 
                                                  (. //WriteStr( 'Constant Name = ' +GetLexString+#13#10) ; .)
         ( "=" 
         [ "@"  ] 
        ConstantDeclBody 
        
        | ":" 
        Type 
        "=" 
         [ "@"  ] 
         ( String 
        
        |  ( "SIZEOF" 
        
        | "BYTE" 
        
        | "ORD"  ) 
        "(" 
        TypedConstant 
        ")" 
        
        | "[" 
                                                  (. WriteStr( 'Entering TypedConstant 0 from ConstDecl' +#13#10) ; .)
        ConstExpr 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } 
        "]" 
         [ AddOp 
        "[" 
        ConstExpr 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } 
        "]"  ] 

        |                                        (. WriteStr( 'Entering TypedConstant 1 from ConstDecl' +#13#10) ; .)
        TypedConstant  ) )
        .
ConstantDeclBody =
                                                  (. //WriteStr( 'In ConstantDeclBody' +#13#10) ; .)
         [ "NOT"  ] 
         [  [                                        (. //WriteStr( 'In ->OrdIdent->' +#13#10) ; .)
        OrdIdent  ] 
                                                  (. //WriteStr( 'Writing Bracket' +#13#10) ; .)
        "("  ] 
                                                  (. //WriteStr( 'Entering ConstExpr ' +#13#10) ; .)
         (                                        (. //WriteStr( 'Entering ->GUIDDef ' +#13#10) ; .)
        GUIDDef 

        |                                        (. WriteStr( 'Entering ->Type' +#13#10) ; .)
        Type 

        |                                        (. //WriteStr( 'Entering ->NumberList ' +#13#10) ; .)
        NumberList 

        |                                        (. //WriteStr( 'Entering ->ConstExpr  ' +#13#10) ; .)
        ConstExpr  ) 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } 
         [ ")" 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } ]
        .
TypedConstant =
                                                  (. //WriteStr( 'In Typed Constant ->' +#13#10) ; .)
        "(" 
        TypedConstantBody 
         {  ( ";" 
        
        | "OR" 
        
        | "," 
        
        | AddOp 
        
        | MulOp  ) 
        TypedConstantBody  } 
        ")"        | 
        "[" 
        ConstExpr 
        "]" 
         {  ( ";" 
        
        | "OR"  ) 
        "[" 
        ConstExpr 
        "]"  }        | 
        TypedConstantBody 
        .
TypedConstantBody =
                                                  (. //WriteStr( 'In Typed ConstantBody ->' +#13#10) ; .)
        "(" 
         ( NumberList 
        
        | VarDecl 
         { ";" 
        VarDecl  } ) 
        ")"        | 
         ( NumberList 
        
        | "[" 
        IdentList 
        "]" 
         {  ( "," 
        
        | "OR"  ) 
        "[" 
        IdentList 
        "]"  } 
        
        | GUIDDef 
        
        | String 
         {  ( "," 
        
        | "OR"  ) 
        ConstExpr  } 
        
        | IdentList  ) 
         [ ":" 
         ( ConstExpr 
        
        | String  ) ]
        .
ImplementationSection =
        "IMPLEMENTATION" 
         { ANY  }
        .
UsesClause =
        "USES" 
        IdentList 
        ";" 
        .
IdentList =
         ( BadNames 
        
        | Ident 
        
        | charnumber  ) 
         {  ( "," 
        
        | "OR"  ) 
         ( BadNames 
        
        | Ident 
        
        | charnumber  ) }
        .
TypeId =
        Type         | 
         ( UnitId 
        "." 
        Type  )
        .
ConstExpr =
                                                  (. WriteStr( 'In ConstExpr  ->' +#13#10) ; .)
         ( "SIZEOF" 
        
        | "BYTE" 
        
        | "ORD" 
        
        | "LONGINT" 
        
        | "INTEGER" 
        
        | "LOW" 
        
        | "HIGH"  ) 
        "(" 
         ( Type 
        
        | String 
        
        | ConstExpr  ) 
        ")" 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr 
        
        | NumberList  }        | 
         [ "NOT"  ] 
         (  (  [ "@"  ] 
        Ident 
         [  ( "(" 
         (                                        (. WriteStr( 'Here  ->' +#13#10) ; .)
        ConstExpr 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr 
        
        | NumberList  } 
        
        | Type  ) 
        ")"  ) ] 
        
        | NumberTypes  ) )        | 
        String 
         [ ".." 
        String  ] 
         { "," 
        String 
         [ ".." 
        String  ] }        | 
        "[" 
         [                                        (. WriteStr( 'IdentList  Here  ->' +#13#10) ; .)
        IdentList 
         [ ".." 
        ConstExpr  ] ] 
        "]"        | 
        charnumber 
         [ charnumber  ] 
         [ ".." 
        ConstExpr  ]        | 
        "(" 
         ( ConstExpr 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } 
        
        | NumberList 
        
        | GUIDDef  ) 
         [ ":" 
        ConstExpr  ] 
        ")"
        .
UnitId =
        Ident 
        .
Ident =
        ident         | 
        ReusableWords 
        .
Number =
         ( number 
        
        | float  )
        .
HexNumber =
         [ "+" 
        
        | "-"  ] 
        hexnumber
        .
ReusableWords =
        "READ"         | 
        "WRITE"         | 
        Directive         | 
        "INDEX"         | 
        "DEFAULT" 
        .
AccessSettings =
        "READONLY"         | 
        "WRITEONLY" 
        .
ResourceString =
        "resourcestring" 
         { Ident 
        "=" 
        String 
         [ "deprecated"  ] 
        ";"  }
        .
String =
        _string 
         { _string 
        
        | charnumber 
         { charnumber  } 
        
        | "+" 
         [ Ident  ] }        | 
        "#" 
