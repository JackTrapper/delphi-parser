         [ "PLATFORM"  ] 
        ";"
        .
RecField =
         ( BadNames 
        
        | IdentList  ) 
        ":" 
         ( "(" 
        VarDecl 
         { ";" 
        VarDecl  } 
        ")" 
        
        | Type  )
        .
ClassHeritage =
        "(" 
                                                  (. SetStart ; .)
        IdentList 
                                                  (. //WriteStr( 'Inherits from ' +CopySourceToCurrent+#13#10) ; .)
        ")" 
        .
ClassPropertyList =
        PropertyList 
        .
ObjectType =
        "OBJECT" 
         [ ObjHeritage  ] 
         [ ObjFieldList  ] 
         [ MethodList  ] 
        "END"
        .
Type =
         [ "SYSTEM" 
        "."  ] 
         (                                        (. WriteStr( ' EnumeratedType ' +#13#10 ) ; .)
