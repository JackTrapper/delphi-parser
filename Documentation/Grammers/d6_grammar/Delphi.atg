        .
SetType =
                                                  (. //WriteStr( 'Set Type ->' +#13#10) ; .)
        "SET" 
        "OF" 
         ( Type 
        
        | SubrangeType  )
        .
FileType =
        "FILE" 
         [ "OF" 
        TypeId  ]
        .
PointerType =
        "^" 
