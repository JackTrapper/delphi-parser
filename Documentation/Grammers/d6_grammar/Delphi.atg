        |                                        (. WriteStr( ' OrdIdent ' +#13#10 ) ; .)
        OrdIdent 

        |                                        (. WriteStr( ' RealType ' +#13#10 ) ; .)
        RealType 

        |                                        (. WriteStr( '  StrucType  ' +#13#10 ) ; .)
        StrucType 

        |                                        (. WriteStr( '   PointerType ' +#13#10 ) ; .)
        PointerType 

        |                                        (. WriteStr( '   StringType  ' +#13#10 ) ; .)
        StringType 

        |                                        (. WriteStr( '   ProcedureType   ' +#13#10 ) ; .)
        ProcedureType 

        |                                        (. WriteStr( '    VariantType  ' +#13#10 ) ; .)
        VariantType 

        |                                        (. WriteStr( '  IdentTypes ' +#13#10 ) ; .)
        IdentTypes 

        |                                        (. WriteStr( '  NumberTypes ' +#13#10 ) ; .)
        NumberTypes  ) 
         [ "PLATFORM" 
        
        | "DEPRECATED"  ]
        .
IdentTypes =
        Ident 
         [ "(" 
         ( ConstExpr 
         {  ( AddOp 
        
        | MulOp 
        
        | "OR" 
        
        | "AND"  ) 
        ConstExpr  } 
        
        | Type  ) 
        ")"  ] 
         [  ( "." 
        Ident 
        
        | ".." 
         ( Ident 
         [ "(" 
         ( ConstExpr 
        
        | Type  ) 
        ")"  ] 
        
        | Number  ) ) ]
        .
NumberTypes =
         [ "+" 
        
