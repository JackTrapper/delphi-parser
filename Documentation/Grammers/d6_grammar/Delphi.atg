         ( HexNumber 
         [  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  ] 
         [ ".." 
        ConstExpr 
         [  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  ] ] 
        
        | Number 
         [ ".." 
                                                  (. WriteStr( 'Entering NumberTypes ConstExpr' +#13#10) ; .)
        ConstExpr 
         {  ( AddOp 
        
        | MulOp  ) 
        ConstExpr  } ] ) 
                                                  (. //WriteStr( 'Leaving NUmberTypes' +#13#10) ; .)
        .
NumberList =
