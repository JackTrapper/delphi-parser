            IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
              _AddOp;
            END ELSE IF _In(symSet[14], sym) THEN BEGIN
              _MulOp;
            END ELSE BEGIN SynError(183);
            END;
            _ConstExpr;
          END ELSE BEGIN
            _NumberList;
          END;
        END;
        END;
      1, 2, 4, 5, 23, 24, 26, 28, 34, 48, 51, 54, 55, 58, 60, 62, 63, 97, 98, 99, 100, 101, 102, 103, 104, 105, 106, 107, 108, 109, 110, 112 : BEGIN
        IF (sym = 112) THEN BEGIN
          PerformGet;
        END;
        IF _In(symSet[30], sym) THEN BEGIN
          IF (sym = 58) THEN BEGIN
            PerformGet;
          END;
          _Ident;
          IF (sym = 17) THEN BEGIN
            PerformGet;
            IF _In(symSet[5], sym) THEN BEGIN
              WriteStr( 'Here  ->' +#13#10) ;
              _ConstExpr;
              WHILE _In(symSet[29], sym) DO BEGIN
                IF _In(symSet[9], sym) THEN BEGIN
                  IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
                    _AddOp;
                  END ELSE IF _In(symSet[14], sym) THEN BEGIN
                    _MulOp;
                  END ELSE BEGIN SynError(184);
                  END;
                  _ConstExpr;
                END ELSE BEGIN
                  _NumberList;
                END;
              END;
            END ELSE IF _In(symSet[11], sym) THEN BEGIN
              _Type;
            END ELSE BEGIN SynError(185);
            END;
            Expect(18);
          END;
        END ELSE IF (sym = 2) OR (sym = 4) OR (sym = 5) OR (sym = 54) OR (sym = 55) THEN BEGIN
          _NumberTypes;
        END ELSE BEGIN SynError(186);
        END;
        END;
      3, 118 : BEGIN
        _String;
        IF (sym = 12) THEN BEGIN
          PerformGet;
          _String;
        END;
        WHILE (sym = 31) DO BEGIN
          PerformGet;
          _String;
          IF (sym = 12) THEN BEGIN
            PerformGet;
            _String;
          END;
        END;
        END;
      15 : BEGIN
        PerformGet;
        IF _In(symSet[2], sym) THEN BEGIN
          WriteStr( 'IdentList  Here  ->' +#13#10) ;
          _IdentList;
          IF (sym = 12) THEN BEGIN
            PerformGet;
            _ConstExpr;
          END;
        END;
        Expect(16);
        END;
      6 : BEGIN
        PerformGet;
        IF (sym = 6) THEN BEGIN
          PerformGet;
        END;
        IF (sym = 12) THEN BEGIN
          PerformGet;
          _ConstExpr;
        END;
        END;
      17 : BEGIN
        PerformGet;
        IF _In(symSet[5], sym) THEN BEGIN
          _ConstExpr;
          WHILE _In(symSet[9], sym) DO BEGIN
            IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
              _AddOp;
            END ELSE BEGIN
              _MulOp;
            END;
            _ConstExpr;
          END;
        END ELSE IF (sym = 2) OR (sym = 4) OR (sym = 5) OR (sym = 54) OR (sym = 55) THEN BEGIN
          _NumberList;
        END ELSE IF (sym = 18) OR (sym = 32) OR (sym = 121) OR (sym = 124) THEN BEGIN
          _GUIDDef;
        END ELSE BEGIN SynError(187);
        END;
        IF (sym = 32) THEN BEGIN
          PerformGet;
          _ConstExpr;
        END;
        Expect(18);
        END;
    ELSE BEGIN SynError(188);
        END;
    END;
  END;

Procedure TDelphiParser._NumberTypes;
  BEGIN
    IF (sym = 54) OR (sym = 55) THEN BEGIN
      IF (sym = 54) THEN BEGIN
        PerformGet;
      END ELSE BEGIN
        PerformGet;
      END;
    END;
    IF (sym = 5) OR (sym = 54) OR (sym = 55) THEN BEGIN
      _HexNumber;
      IF _In(symSet[9], sym) THEN BEGIN
        IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
          _AddOp;
        END ELSE BEGIN
          _MulOp;
        END;
        _ConstExpr;
      END;
      IF (sym = 12) THEN BEGIN
        PerformGet;
        _ConstExpr;
        IF _In(symSet[9], sym) THEN BEGIN
          IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
            _AddOp;
          END ELSE BEGIN
            _MulOp;
          END;
          _ConstExpr;
        END;
      END;
    END ELSE IF (sym = 2) OR (sym = 4) THEN BEGIN
      _Number;
      IF (sym = 12) THEN BEGIN
        PerformGet;
        WriteStr( 'Entering NumberTypes ConstExpr' +#13#10) ;
        _ConstExpr;
        WHILE _In(symSet[9], sym) DO BEGIN
          IF (sym = 52) OR (sym = 54) OR (sym = 55) OR (sym = 70) THEN BEGIN
            _AddOp;
          END ELSE BEGIN
            _MulOp;
          END;
          _ConstExpr;
        END;
      END;
    END ELSE BEGIN SynError(189);
    END;
    //WriteStr( 'Leaving NUmberTypes' +#13#10) ;
  END;

Procedure TDelphiParser._ClassTypeGroup;
  BEGIN
    Expect(35);
    IF (sym = 39) THEN BEGIN
      _ClassRefBody;
    END ELSE IF _In(symSet[31], sym) THEN BEGIN
      _ClassTypeBody;
    END ELSE BEGIN SynError(190);
    END;
  END;

Procedure TDelphiParser._RestrictedType;
  BEGIN
    IF (sym = 49) THEN BEGIN
      _ObjectType;
    END ELSE IF (sym = 9) OR (sym = 13) THEN BEGIN
      _InterfaceType;
    END ELSE BEGIN SynError(191);
    END;
  END;

Procedure TDelphiParser._TypeId;
  BEGIN
    IF _In(symSet[11], sym) THEN BEGIN
      _Type;
    END ELSE IF _In(symSet[8], sym) THEN BEGIN
      _UnitId;
      Expect(25);
      _Type;
    END ELSE BEGIN SynError(192);
    END;
  END;

Procedure TDelphiParser._TypeDecl;
  //var S : String ;
  BEGIN
    IF _In(symSet[8], sym) THEN BEGIN
      _Ident;
    END ELSE IF _In(symSet[7], sym) THEN BEGIN
      _BadNames;
    END ELSE BEGIN SynError(193);
    END;
    //S := GetLexString ;
     // WriteStr( 'TypeName =' +S+#13#10) ;
    Expect(11);
    IF (sym = 10) THEN BEGIN
      PerformGet;
    END;
    IF _In(symSet[11], sym) THEN BEGIN
      WriteStr( 'Entering TypeId ' +#13#10) ;
      _TypeId;
    END ELSE IF (sym = 9) OR (sym = 13) OR (sym = 49) THEN BEGIN
      _RestrictedType;
    END ELSE IF (sym = 35) THEN BEGIN
      _ClassTypeGroup;
    END ELSE IF (sym = 2) OR (sym = 4) OR (sym = 5) OR (sym = 54) OR (sym = 55) THEN BEGIN
      _NumberTypes;
    END ELSE IF _In(symSet[5], sym) THEN BEGIN
      //WriteStr( 'In Const Expr Hunt ' ) ;
      _ConstExpr;
      IF (sym = 12) THEN BEGIN
        PerformGet;
        _ConstExpr;
      END;
    END ELSE BEGIN SynError(194);
    END;
    //WriteStr( 'End of Type =' +S+#13#10) ;
  END;

Procedure TDelphiParser._ResourceString;
  BEGIN
    Expect(117);
    WHILE _In(symSet[8], sym) DO BEGIN
      _Ident;
      Expect(11);
      _String;
      IF (sym = 51) THEN BEGIN
        PerformGet;
      END;
      Expect(8);
    END;
  END;

Procedure TDelphiParser._ExportedHeading;
  BEGIN
    IF (sym = 59) THEN BEGIN
      _ProcedureHeading;
    END ELSE IF (sym = 61) THEN BEGIN
      _FunctionHeading;
    END ELSE BEGIN SynError(195);
    END;
    Expect(8);
    WHILE _In(symSet[1], sym) DO BEGIN
      _Directive;
      Expect(8);
    END;
  END;

Procedure TDelphiParser._VarSection;
  BEGIN
    Expect(56);
    WHILE _In(symSet[2], sym) DO BEGIN
      _VarDecl;
      IF _In(symSet[1], sym) THEN BEGIN
        _Directive;
      END;
      Expect(8);
      IF _In(symSet[1], sym) THEN BEGIN
        _Directive;
        Expect(8);
      END;
    END;
  END;

Procedure TDelphiParser._TypeSection;
  BEGIN
    Expect(10);
    WHILE _In(symSet[17], sym) DO BEGIN
      //WriteStr( 'New TypeDecl ->' +#13#10) ;
      _TypeDecl;
      //WriteStr( 'Closing Semi-Coloon ->' +#13#10) ;
      Expect(8);
      WHILE _In(symSet[1], sym) DO BEGIN
        _Directive;
        Expect(8);
      END;
    END;
  END;

Procedure TDelphiParser._ConstSection;
  BEGIN
    Expect(40);
    //WriteStr( 'In "CONST" ' +#13#10) ;
    _ConstantDecl;
    Expect(8);
    WHILE _In(symSet[17], sym) DO BEGIN
      _ConstantDecl;
      Expect(8);
    END;
  END;

Procedure TDelphiParser._InterfaceDecl;
  BEGIN
    IF (sym = 40) THEN BEGIN
      //WriteStr( 'ConstSection ->' +#13#10) ;
      _ConstSection;
    END ELSE IF (sym = 10) THEN BEGIN
      //WriteStr( 'TypeSection ->' +#13#10) ;
      _TypeSection;
    END ELSE IF (sym = 56) THEN BEGIN
      //WriteStr( 'VarSection  ->' +#13#10) ;
      _VarSection;
    END ELSE IF (sym = 59) OR (sym = 61) THEN BEGIN
      _ExportedHeading;
    END ELSE IF (sym = 117) THEN BEGIN
      _ResourceString;
    END ELSE BEGIN SynError(196);
    END;
  END;

Procedure TDelphiParser._UsesClause;
  BEGIN
    Expect(114);
    _IdentList;
    Expect(8);
  END;

Procedure TDelphiParser._ImplementationSection;
  BEGIN
