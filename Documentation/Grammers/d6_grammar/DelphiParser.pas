Procedure TDelphiParser._Unit;
  BEGIN
    Expect(7);
    IF _In(symSet[8], sym) THEN BEGIN
      _Ident;
    END ELSE IF _In(symSet[7], sym) THEN BEGIN
      _BadNames;
    END ELSE BEGIN SynError(200);
    END;
    IF _In(symSet[1], sym) THEN BEGIN
      _Directive;
    END;
    Expect(8);
    _InterfaceSection;
    _ImplementationSection;
  END;

Procedure TDelphiParser._SourceFile;
  BEGIN
